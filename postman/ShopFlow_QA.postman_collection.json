          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Product details returns 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Product has required fields', function () { const p = pm.response.json(); pm.expect(p).to.have.property('id'); pm.expect(p).to.have.property('name'); pm.expect(p).to.have.property('price'); });"
            ]
          }
        }
      ]
    },
