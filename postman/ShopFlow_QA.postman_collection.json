{
  "info": {
    "_postman_id": "shopflow-real-app-qa-suite",
    "name": "ShopFlow QA Validation Suite - Real App",
    "description": "Postman collection for the ShopFlow React/Express/PostgreSQL e-commerce demo app.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('API status is ok', function () { pm.expect(pm.response.json().status).to.eql('ok'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Register Customer With Unique Email",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/auth/register",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Postman QA User\",\n  \"email\": \"postman_qa_{{$timestamp}}@example.com\",\n  \"password\": \"Password123!\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Register returns 201', function () { pm.response.to.have.status(201); });",
              "pm.test('Token exists', function () { pm.expect(pm.response.json().token).to.exist; });"
            ]
          }
        }
      ]
    },
    {
      "name": "Login Customer",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"customer@example.com\",\n  \"password\": \"Password123!\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login returns 200', function () { pm.response.to.have.status(200); });",
              "const data = pm.response.json();",
              "pm.test('Customer token exists', function () { pm.expect(data.token).to.exist; });",
              "pm.collectionVariables.set('token', data.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Products",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/products",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "products"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Products returns 200', function () { pm.response.to.have.status(200); });",
              "const products = pm.response.json();",
              "pm.test('Products is array', function () { pm.expect(products).to.be.an('array'); });",
              "if (products.length > 0) { pm.collectionVariables.set('product_id', products[0].id); }"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Product Details",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/products/{{product_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
