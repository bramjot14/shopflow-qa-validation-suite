          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Add to cart returns 201', function () { pm.response.to.have.status(201); });",
              "const data = pm.response.json();",
              "pm.test('Cart has items', function () { pm.expect(data.items.length).to.be.above(0); });",
              "pm.collectionVariables.set('cart_item_id', data.items[0].cart_item_id);"
            ]
          }
        }
      ]
    },
